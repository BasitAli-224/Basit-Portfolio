<script>

/* ================================================================
   SECTION 1 — PROJECT DATA  ← THE ONLY PLACE YOU NEED TO EDIT
   ──────────────────────────────────────────────────────────────
   Fields:
     title       — project name shown on card & modal
     category    — used for filter chips (keep spelling consistent)
     description — shown in the modal under the video
     thumbnail   — path to thumbnail image, e.g. "thumbs/neon.jpg"
                   leave "" for placeholder
     videoUrl    — YouTube embed URL
                   From: youtube.com/watch?v=VIDEOID
                   Use:  "https://www.youtube.com/embed/VIDEOID"

   ── ADD NEW PROJECT HERE (copy block below & paste before ]) ──
================================================================ */
const projects = [
  {
    title:       "Neon Horizon",
    category:    "Commercial",
    description: "Cyberpunk-inspired commercial reel with custom 3D typography and glitch effects.",
    thumbnail:   "",                                            // EDIT THUMBNAIL
    videoUrl:    "https://www.youtube.com/embed/dQw4w9WgXcQ"  // EDIT VIDEO LINK
  },
  {
