<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Basit Ali — Video Editor & Motion Graphics Artist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>

/* ================================================================
   BASE RESET & VARIABLES
================================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --teal:        #00dddd;
  --teal-dim:    #00aaaa;
  --purple:      #c084fc;
  --bg:          #080b0e;
  --bg2:         #0d1117;
  --card:        #0f1318;
  --card2:       #141a20;
  --on-surface:  #ffffff;
  --muted:       #8a9ab0;
  --ease:        cubic-bezier(0.22,1,0.36,1);
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--on-surface);
  overflow-x: hidden;
}

/* ================================================================
   NAVIGATION
================================================================ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  height: 60px;
  background: rgba(8,11,14,0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(0,221,221,0.08);
}

.nav-logo {
  font-weight: 900;
  font-size: 1.1rem;
  color: var(--teal);
  letter-spacing: 0.06em;
  text-decoration: none;
}

.nav-links { display: flex; list-style: none; gap: 2rem; }

.nav-links a {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--muted);
  text-decoration: none;
  padding-bottom: 3px;
  border-bottom: 2px solid transparent;
  transition: color 0.3s ease, border-color 0.3s ease;
}

.nav-links a.active { color: var(--on-surface); border-bottom-color: var(--teal); }
.nav-links a:hover  { color: var(--on-surface); }

.nav-cta {
  background: var(--teal);
  color: #000;
  font-weight: 700;
  font-size: 0.78rem;
  padding: 0.5rem 1.3rem;
  border-radius: 6px;
  text-decoration: none;
  letter-spacing: 0.02em;
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}

.nav-cta:hover {
  box-shadow: 0 0 20px rgba(0,221,221,0.5);
  transform: translateY(-1px);
}

/* ================================================================
   HERO
================================================================ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--bg);
  padding-top: 60px;
}

/* Hex dot grid */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,221,221,0.1) 1px, transparent 1px);
  background-size: 28px 28px;
  z-index: 0;
}

/* Animated neon blobs */
.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
  z-index: 1;
  animation: blobFloat 10s ease-in-out infinite alternate;
}

.blob-a {
  width: 700px; height: 220px;
  background: rgba(0,200,200,0.12);
  bottom: 14%; left: -10%;
  border-radius: 60% 40% 55% 45%;
  animation-duration: 9s;
}

.blob-b {
  width: 520px; height: 180px;
  background: rgba(192,132,252,0.11);
  top: 20%; right: -6%;
  border-radius: 40% 60% 45% 55%;
  animation-duration: 12s;
  animation-delay: -5s;
}

.blob-c {
  width: 300px; height: 140px;
  background: rgba(0,180,180,0.07);
  top: 40%; left: 28%;
  animation-duration: 14s;
  animation-delay: -3s;
}

@keyframes blobFloat {
  0%   { transform: translate(0,0) scale(1);    opacity: 0.75; }
  50%  { transform: translate(18px,-12px) scale(1.04); opacity: 1; }
  100% { transform: translate(-10px,10px) scale(0.97); opacity: 0.7; }
}

.hero-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 3rem;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 40px 60px;
}

.hero-left { display: flex; flex-direction: column; gap: 1.2rem; }

.available-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  width: fit-content;
  border: 1px solid rgba(0,221,221,0.6);
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--teal);
}

.available-badge::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--teal);
  animation: pulseGreen 2s ease-in-out infinite;
}

@keyframes pulseGreen {
  0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(0,221,221,0.4); }
  50%       { opacity: 0.6; transform: scale(0.7); box-shadow: 0 0 0 4px rgba(0,221,221,0); }
}

.hero-name {
  font-size: clamp(3rem, 7.5vw, 5.8rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.025em;
}

.hero-name .teal { color: var(--teal); }

.hero-roles { display: flex; flex-direction: column; gap: 0.2rem; }

.hero-roles span {
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--muted);
  line-height: 1.6;
}

.hero-btns { display: flex; gap: 1rem; margin-top: 0.5rem; }

.btn-teal {
  display: inline-block;
  background: var(--teal);
  color: #000;
  font-weight: 700;
  font-size: 0.85rem;
  padding: 0.7rem 1.75rem;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: box-shadow 0.35s var(--ease), transform 0.35s var(--ease);
}

.btn-teal:hover {
  box-shadow: 0 0 26px rgba(0,221,221,0.55);
  transform: translateY(-2px);
}

.btn-outline {
  display: inline-block;
  background: transparent;
  color: var(--on-surface);
  font-weight: 600;
  font-size: 0.85rem;
  padding: 0.7rem 1.75rem;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.22);
  cursor: pointer;
  text-decoration: none;
  transition: border-color 0.3s ease, background 0.3s ease;
}

.btn-outline:hover {
  border-color: rgba(0,221,221,0.5);
  background: rgba(0,221,221,0.05);
}

/* Hero image */
.hero-right { display: flex; justify-content: center; align-items: center; }

.hero-img-wrap {
  position: relative;
  width: 100%;
  max-width: 580px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(0,221,221,0.1),
    0 0 70px rgba(0,221,221,0.07),
    0 30px 80px rgba(0,0,0,0.65);
}

.hero-img-wrap img {
  width: 100%;
  height: auto;
  display: block;
}

.hero-img-placeholder {
  width: 100%;
  padding-top: 62%;
  position: relative;
  background: linear-gradient(135deg, #0d1520, #111a28);
  border-radius: 16px;
}

.hero-img-placeholder span {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 0.78rem;
  color: var(--muted);
  flex-direction: column;
  gap: 6px;
}

/* ================================================================
   SELECTED WORKS
================================================================ */
.works-section {
  background: #0d1117;
  padding: 90px 40px;
}

.works-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
}

.works-header-left h2 {
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800;
  margin-bottom: 0.6rem;
}

.works-header-left h2 .purple { color: var(--purple); }

.works-header-left p {
  font-size: 0.87rem;
  color: var(--muted);
  max-width: 380px;
  line-height: 1.65;
}

.filter-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: flex-start; }

.chip {
  background: rgba(0,221,221,0.08);
  color: var(--teal);
  border: 1px solid rgba(0,221,221,0.2);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.chip.active,
.chip:hover {
  background: rgba(0,221,221,0.18);
  box-shadow: 0 0 14px rgba(0,221,221,0.2);
}

/* Portfolio grid */
.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 1.25rem;
  max-width: 1200px;
  margin: 0 auto;
}

/* Cards */
.project-card {
  background: var(--card);
  border-radius: 14px;
  overflow: hidden;
  cursor: pointer;
  border: 1px solid rgba(255,255,255,0.05);
  transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease);
}

.project-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 0 40px rgba(0,221,221,0.1), 0 20px 50px rgba(0,0,0,0.5);
}

.card-thumb {
  position: relative;
  padding-top: 58%;
  overflow: hidden;
  background: #0a0f14;
}

.card-thumb img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s var(--ease);
}

.project-card:hover .card-thumb img { transform: scale(1.07); }

.card-badge {
  position: absolute;
  top: 12px; right: 12px;
  background: rgba(0,221,221,0.15);
  color: var(--teal);
  border: 1px solid rgba(0,221,221,0.35);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
  backdrop-filter: blur(6px);
  z-index: 2;
}

.card-play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.28);
  opacity: 0;
  transition: opacity 0.4s var(--ease);
}

.project-card:hover .card-play-overlay { opacity: 1; }

.play-btn-circle {
  width: 54px; height: 54px;
  border-radius: 50%;
  background: rgba(0,221,221,0.15);
  backdrop-filter: blur(8px);
  border: 1.5px solid var(--teal);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
}

.project-card:hover .play-btn-circle {
  transform: scale(1.12);
  box-shadow: 0 0 24px rgba(0,221,221,0.55);
}

.play-btn-circle svg { width: 20px; height: 20px; fill: var(--teal); margin-left: 3px; }

/* Thumb placeholder */
.thumb-ph {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #0a0f16, #121a22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-ph svg { width: 36px; height: 36px; fill: none; stroke: rgba(0,221,221,0.2); stroke-width: 1.5; }

.card-body { padding: 1rem 1.25rem 1.25rem; }

.card-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 0.4rem;
}

.card-desc {
  font-size: 0.77rem;
  color: var(--muted);
  line-height: 1.55;
}

.project-card.hidden { display: none; }

/* ================================================================
   WHY COLLABORATE
================================================================ */
.collab-section {
  background: var(--bg);
  padding: 90px 40px;
  text-align: center;
}

.collab-section h2 {
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  font-weight: 800;
  margin-bottom: 0.5rem;
}

.collab-section h2 .teal { color: var(--teal); }

.collab-section > p {
  font-size: 0.88rem;
  color: var(--muted);
  margin-bottom: 3rem;
}

.collab-grid {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  max-width: 1100px;
  margin: 0 auto;
}

.collab-card {
  background: var(--card);
  border: 1px solid rgba(0,221,221,0.14);
  border-radius: 12px;
  padding: 1.5rem 1.25rem;
  flex: 1;
  min-width: 160px;
  max-width: 195px;
  text-align: center;
  transition: border-color 0.35s ease, box-shadow 0.35s ease, transform 0.35s ease;
}

.collab-card:hover {
  border-color: rgba(0,221,221,0.45);
  box-shadow: 0 0 22px rgba(0,221,221,0.1);
  transform: translateY(-4px);
}

.collab-icon {
  width: 44px; height: 44px;
  margin: 0 auto 1rem;
  background: rgba(0,221,221,0.1);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collab-icon svg {
  width: 22px; height: 22px;
  stroke: var(--teal);
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.collab-card h3 {
  font-size: 0.87rem;
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 0.45rem;
}

.collab-card p {
  font-size: 0.73rem;
  color: var(--muted);
  line-height: 1.55;
}

/* ================================================================
   CONTACT
================================================================ */
.contact-section {
  background: #0d1117;
  padding: 90px 40px;
}

.contact-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 4rem;
  align-items: start;
}

.contact-left h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 1rem;
}

.contact-left h2 .teal { color: var(--teal); }

.contact-left > p {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.65;
  margin-bottom: 2rem;
  max-width: 380px;
}

.contact-meta { display: flex; flex-direction: column; gap: 0.85rem; }

.contact-meta-item { display: flex; align-items: center; gap: 10px; }

.meta-icon {
  width: 34px; height: 34px;
  background: rgba(0,221,221,0.1);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.meta-icon svg { width: 16px; height: 16px; stroke: var(--teal); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

.meta-text { display: flex; flex-direction: column; }
.meta-text small { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1px; }
.meta-text a { font-size: 0.85rem; font-weight: 500; color: var(--on-surface); text-decoration: none; transition: color 0.3s ease; }
.meta-text a:hover { color: var(--teal); }

/* Form */
.contact-form { display: flex; flex-direction: column; gap: 1rem; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.form-field { display: flex; flex-direction: column; gap: 5px; }

.form-field label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--muted);
}

.form-field input,
.form-field textarea {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  color: var(--on-surface);
  font-family: 'Inter', sans-serif;
  font-size: 0.87rem;
  outline: none;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.form-field input::placeholder,
.form-field textarea::placeholder { color: rgba(255,255,255,0.18); }

.form-field input:focus,
.form-field textarea:focus {
  border-color: rgba(0,221,221,0.45);
  box-shadow: 0 0 0 3px rgba(0,221,221,0.08);
}

.form-field textarea { resize: vertical; min-height: 130px; }

.btn-submit {
  width: 100%;
  background: var(--teal);
  color: #000;
  font-family: 'Inter', sans-serif;
  font-size: 0.92rem;
  font-weight: 700;
  padding: 0.875rem;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  letter-spacing: 0.03em;
  transition: box-shadow 0.35s ease, transform 0.35s ease, background 0.3s ease;
}

.btn-submit:hover {
  box-shadow: 0 0 26px rgba(0,221,221,0.55);
  transform: translateY(-2px);
}

/* ================================================================
   FOOTER
================================================================ */
footer {
  background: var(--bg);
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 1.5rem 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-logo { font-weight: 900; font-size: 1rem; color: var(--teal); letter-spacing: 0.06em; }

footer p { font-size: 0.78rem; color: var(--muted); }

.footer-links { display: flex; gap: 1.5rem; list-style: none; }

.footer-links a {
  font-size: 0.8rem;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.3s ease;
}

.footer-links a:hover { color: var(--teal); }

/* ================================================================
   MODAL
================================================================ */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  background: rgba(0,0,0,0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s var(--ease);
}

.modal-overlay.open { opacity: 1; pointer-events: all; }

.modal-box {
  position: relative;
  width: 100%;
  max-width: 900px;
  background: var(--card2);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(0,221,221,0.15);
  transform: scale(0.95) translateY(20px);
  transition: transform 0.45s var(--ease);
  box-shadow: 0 0 80px rgba(0,0,0,0.7);
}

.modal-overlay.open .modal-box { transform: scale(1) translateY(0); }

.modal-video-wrap { position: relative; padding-top: 56.25%; background: #000; }

.modal-video-wrap iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
}

.modal-footer {
  padding: 1.1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.modal-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 3px;
}

.modal-desc {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.55;
}

.modal-close {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.3s ease, border-color 0.3s ease;
}

.modal-close:hover {
  background: rgba(0,221,221,0.12);
  border-color: var(--teal);
}

.modal-close svg { width: 14px; height: 14px; stroke: var(--on-surface); fill: none; stroke-width: 2; stroke-linecap: round; }

/* ================================================================
   RESPONSIVE
================================================================ */
@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; text-align: center; padding: 60px 24px 50px; }
  .hero-right  { display: none; }
  .hero-btns   { justify-content: center; }
  .available-badge { margin: 0 auto; }
  nav { padding: 0 24px; }
  .works-section, .collab-section, .contact-section { padding: 60px 24px; }
  footer { padding: 1.5rem 24px; }
  .portfolio-grid { grid-template-columns: repeat(2,1fr); }
  .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
}

@media (max-width: 600px) {
  .nav-links   { display: none; }
  .form-row    { grid-template-columns: 1fr; }
  .portfolio-grid { grid-template-columns: 1fr; }
  .collab-card { max-width: 100%; }
}

  </style>
</head>
<body>

<!-- ================================================================
     NAVIGATION
================================================================ -->
<nav>
  <a href="#home" class="nav-logo">BA</a>
  <ul class="nav-links">
    <li><a href="#home" class="active">Home</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#portfolio" class="nav-cta">View My Work</a>
</nav>

<!-- ================================================================
     HERO
================================================================ -->
<section class="hero" id="home">
  <div class="blob blob-a"></div>
  <div class="blob blob-b"></div>
  <div class="blob blob-c"></div>

  <div class="hero-inner">
    <div class="hero-left">
      <div class="available-badge">Available for Projects</div>

      <h1 class="hero-name">Basit <span class="teal">Ali</span></h1>

      <div class="hero-roles">
